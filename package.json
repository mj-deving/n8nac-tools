{
  "name": "n8nac-tools",
  "version": "1.0.0",
  "description": "CLI-first tool wrapping n8nac commands for humans, AI agents, and MCP clients",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "n8nac-tools": "dist/index.js"
  },
  "files": [
